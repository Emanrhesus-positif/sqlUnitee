# .env.example - Template de variables d'environnement
#
# INSTRUCTIONS :
# 1. Copier ce fichier en ".env" : cp .env.example .env
# 2. Remplir les valeurs réelles
# 3. NE PAS commiter .env en git (déjà dans .gitignore)
# 4. Laisser .env.example dans git (template pour autres développeurs)
#
# Date : 8 avril 2026

################################################################################
# 1. BASE DE DONNÉES MYSQL
################################################################################

# Host de la base de données
DB_HOST=localhost

# Port MySQL (défaut 3306)
DB_PORT=3306

# Utilisateur MySQL
# ⚠️ Ne pas utiliser root en production
DB_USER=unitee_user

# Mot de passe MySQL
# 💪 Utiliser un mot de passe fort (min 12 caractères, mix alphanumériques + spéciaux)
DB_PASS=change_me_strong_password_12345!

# Nom de la base de données
DB_NAME=unitee

# Charset pour MySQL
DB_CHARSET=utf8mb4

# Collation pour MySQL
DB_COLLATION=utf8mb4_unicode_ci

################################################################################
# 2. JUPYTER NOTEBOOK
################################################################################

# Mode de démarrage Jupyter
# Options: auto, lab (JupyterLab), notebook (Jupyter Notebook classique)
JUPYTER_MODE=lab

# Port Jupyter
JUPYTER_PORT=8888

# Token/Password (laisser vide pour auto-généré)
JUPYTER_TOKEN=

################################################################################
# 3. APIS EXTERNES
################################################################################

# API data.gouv.fr (généralement pas de clé required)
# Mais au cas où (futures améliorations) :
DATA_GOUV_FR_API_KEY=

# API BOAMP (à découvrir J2)
# Si authentification required :
BOAMP_API_KEY=
BOAMP_API_SECRET=

################################################################################
# 4. CONFIGURATION APPLICATION
################################################################################

# Mode d'exécution
# Options: development, testing, production
APP_ENV=development

# Level de logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Chemin fichier configuration YAML
CONFIG_FILE=./config/config.yaml

# Chemin fichier configuration sources API
SOURCES_CONFIG_FILE=./config/sources_config.yaml

################################################################################
# 5. SAUVEGARDE & ARCHIVAGE
################################################################################

# Dossier sauvegarde
BACKUP_DIR=./backups

# Enable/disable sauvegarde automatique
BACKUP_ENABLED=true

# Heure sauvegarde (format HH:MM)
BACKUP_TIME=22:00

# Nombre jours à retenir les backups
BACKUP_RETENTION_DAYS=30

################################################################################
# 6. NOTIFICATIONS (optionnel, pour futures alerts email)
################################################################################

# Email SMTP pour alertes
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email destinataires des alertes (comma-separated)
ALERT_EMAIL_TO=recipient@example.com

# Enable/disable email
EMAIL_ENABLED=false

################################################################################
# 7. WEBHOOK (optionnel, pour futures intégrations)
################################################################################

# URL webhook pour notifications
WEBHOOK_URL=

# Secret webhook (si authentication required)
WEBHOOK_SECRET=

# Enable/disable webhook
WEBHOOK_ENABLED=false

################################################################################
# 8. ADVANCED / DÉVELOPPEMENT
################################################################################

# Debug mode (affiche logs verbeux)
DEBUG=false

# Sauvegarder données intermédiaires
SAVE_INTERMEDIATE_DATA=true

# Utiliser données synthétiques (test)
USE_FALLBACK_DATA=false

# Timeout requêtes API (secondes)
API_TIMEOUT=30

# Max retries API
API_MAX_RETRIES=3

################################################################################
# 9. DOCKER COMPOSE
################################################################################

# Ces variables sont utilisées par docker-compose.yml

# Mot de passe root MySQL pour Docker
MYSQL_ROOT_PASSWORD=root_password_123456!

# Port MySQL sur host (mapping docker)
MYSQL_PORT_HOST=3306

# Port PhpMyAdmin sur host
PHPMYADMIN_PORT=8080

################################################################################
# NOTES IMPORTANTES
################################################################################

# ⚠️ SÉCURITÉ :
# • Jamais commiter ce fichier rempli en git
# • Utiliser des passwords forts
# • Changer les valeurs par défaut
# • Ne pas utiliser en production sans sécuriser les secrets
#
# 🔐 Alternatives sécurisées en production :
# • Utiliser AWS Secrets Manager, Azure Key Vault, etc.
# • Utiliser docker secrets (Docker Swarm/Kubernetes)
# • Chiffrer .env avec git-crypt ou similar
#
# 📝 Après modif :
# • Tester connexion BD : mysql -h localhost -u unitee_user -p
# • Vérifier notebook peux se connecter (Onglet 1)
# • Jamais commit .env : git status pour vérifier
#

################################################################################
# CHECKLIST SETUP
################################################################################

# ✅ Avant de démarrer :
#
# [ ] Copier ce fichier : cp .env.example .env
# [ ] Remplir TOUTES les valeurs ci-dessus
# [ ] Vérifier .env est dans .gitignore
# [ ] Tester connexion BD
# [ ] Lancer Docker : docker-compose up -d
# [ ] Attendre 30s MySQL startup
# [ ] Tester Jupyter : jupyter notebook
# [ ] Exécuter Unitee.ipynb Onglet 1 (Setup)
#
