@startuml PHYSIQUE_Unitee
!theme plain

title PHYSIQUE - UNITEE MySQL 8.0 Physical Schema

entity sources {
  *id_source : INT PK
  --
  source_name : VARCHAR(100) UNIQUE
  description : TEXT
  url_base : VARCHAR(500)
  type_source : ENUM
  active : BOOLEAN
  created_at : DATETIME
}

entity buyers {
  *id_buyer : INT PK
  --
  buyer_name : VARCHAR(255) UNIQUE
  buyer_type : ENUM
  region : VARCHAR(100)
  contact_email : VARCHAR(255)
  contact_phone : VARCHAR(20)
  created_at : DATETIME
}

entity keywords {
  *id_keyword : INT PK
  --
  keyword_text : VARCHAR(100) UNIQUE
  category : ENUM
  relevance_score : INT
  created_at : DATETIME
}

entity announcements {
  *id_announcement : BIGINT PK
  #id_source : INT FK
  #id_buyer : INT FK
  --
  external_id : VARCHAR(100)
  title : VARCHAR(500)
  description : LONGTEXT
  estimated_amount : DECIMAL(15,2)
  currency : VARCHAR(3)
  publication_date : DATETIME
  response_deadline : DATETIME
  location : VARCHAR(255)
  region : VARCHAR(100)
  source_link : TEXT UNIQUE
  status : ENUM
  imported_at : DATETIME
  updated_at : DATETIME
}

entity announcement_keywords {
  *id_announcement : BIGINT PK
  *id_keyword : INT PK
  --
  relevance_score : INT
  extraction_type : ENUM
  extracted_at : DATETIME
}

entity qualification_scores {
  *id_score : INT PK
  #id_announcement : BIGINT UNIQUE FK
  --
  pertinence_score : INT
  alert_level : ENUM
  scoring_reason : TEXT
  keyword_bonus : INT
  amount_bonus : INT
  deadline_bonus : INT
  buyer_bonus : INT
  calculated_at : DATETIME
  updated_at : DATETIME
}

entity notifications {
  *id_notification : BIGINT PK
  #id_announcement : BIGINT FK
  --
  alert_type : VARCHAR(50)
  status : ENUM
  priority : INT
  created_at : DATETIME
  sent_at : DATETIME
  acknowledged_at : DATETIME
  message : LONGTEXT
}

entity technical_logs {
  *id_log : BIGINT PK
  --
  timestamp : DATETIME
  operation_type : VARCHAR(100)
  operation_source : VARCHAR(100)
  status : ENUM
  message : TEXT
  details_json : JSON
  duration_ms : INT
}

entity business_logs {
  *id_log : BIGINT PK
  #id_announcement : BIGINT FK
  --
  timestamp : DATETIME
  operation_type : VARCHAR(100)
  user : VARCHAR(255)
  description : TEXT
  before_state : JSON
  after_state : JSON
}

entity announcement_history {
  *id_history : BIGINT PK
  #id_announcement : BIGINT FK
  --
  timestamp : DATETIME
  modification_type : VARCHAR(100)
  modified_column : VARCHAR(100)
  old_value : TEXT
  new_value : TEXT
}

entity backup_logs {
  *id_backup : INT PK
  --
  timestamp : DATETIME
  backup_type : ENUM
  backup_file : VARCHAR(500)
  status : ENUM
  file_size : BIGINT
  duration_seconds : INT
  error_message : TEXT
}

sources ||--o{ announcements
buyers ||--o{ announcements
announcements }o--|| announcement_keywords
keywords ||--o{ announcement_keywords
announcements ||--|| qualification_scores
announcements ||--o{ notifications
announcements ||--o{ business_logs
announcements ||--o{ announcement_history

note bottom
  Legend:
  * = Primary Key
  # = Foreign Key
  RESTRICT = FK delete policy
  CASCADE = Auto-delete related
end note

@enduml
