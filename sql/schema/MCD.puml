@startuml MCD_Unitee
!theme plain

title MCD - UNITEE Public Market Surveillance System

entity SOURCE {
  *source_id
  --
  source_name
  description
  api_base_url
  source_type
}

entity BUYER {
  *buyer_id
  --
  buyer_name
  buyer_type
  region
  contact_email
}

entity KEYWORD {
  *keyword_id
  --
  keyword_text
  category
}

entity ANNOUNCEMENT {
  *announcement_id
  #source_id
  #buyer_id
  --
  external_id
  title
  description
  estimated_amount
  publication_date
  response_deadline
  location
  source_link
  status
  import_timestamp
}

entity ANNOUNCEMENT_KEYWORD {
  *announcement_id
  *keyword_id
  --
  relevance_score
  extraction_type
  extraction_date
}

entity QUALIFICATION {
  *score_id
  #announcement_id
  --
  pertinence_score
  alert_level
  scoring_reason
  keyword_bonus
  amount_bonus
  deadline_bonus
  buyer_bonus
}

entity NOTIFICATION {
  *notification_id
  #announcement_id
  --
  alert_type
  status
  priority
  creation_date
  sent_date
  acknowledged_date
}

entity TECHNICAL_LOG {
  *log_id
  --
  timestamp
  operation_type
  operation_source
  status
  message
  details_json
  duration_ms
}

entity BUSINESS_LOG {
  *business_log_id
  #announcement_id
  --
  timestamp
  operation_type
  user
  description
  before_state
  after_state
}

entity ANNOUNCEMENT_HISTORY {
  *history_id
  #announcement_id
  --
  timestamp
  modification_type
  modified_column
  old_value
  new_value
}

entity BACKUP_LOG {
  *backup_id
  --
  timestamp
  backup_type
  backup_file
  status
  file_size
  duration_seconds
}

SOURCE ||--o{ ANNOUNCEMENT
BUYER ||--o{ ANNOUNCEMENT
ANNOUNCEMENT }o--|| ANNOUNCEMENT_KEYWORD
KEYWORD ||--o{ ANNOUNCEMENT_KEYWORD
ANNOUNCEMENT ||--|| QUALIFICATION
ANNOUNCEMENT ||--o{ NOTIFICATION
ANNOUNCEMENT ||--o{ BUSINESS_LOG
ANNOUNCEMENT ||--o{ ANNOUNCEMENT_HISTORY

note right of ANNOUNCEMENT
  Composite UNIQUE key:
  (source_id, external_id)
end note

note right of ANNOUNCEMENT_KEYWORD
  N:N linking table
  Only place for
  relevance_score
end note

note right of TECHNICAL_LOG
  System operations
  No FK needed
end note

note right of BACKUP_LOG
  Backup tracking
  Independent entity
end note

@enduml
