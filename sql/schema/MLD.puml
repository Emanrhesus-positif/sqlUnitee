@startuml MLD_Unitee
!theme plain

title MLD - UNITEE Logical Data Model

entity SOURCES {
  *source_id : INT
  --
  source_name : VARCHAR(100)
  description : TEXT
  api_base_url : VARCHAR(500)
  source_type : VARCHAR(50)
  active : BOOLEAN
  created_at : DATETIME
}

entity BUYERS {
  *buyer_id : INT
  --
  buyer_name : VARCHAR(255)
  buyer_type : VARCHAR(100)
  region : VARCHAR(100)
  contact_email : VARCHAR(255)
  contact_phone : VARCHAR(20)
  created_at : DATETIME
}

entity KEYWORDS {
  *keyword_id : INT
  --
  keyword_text : VARCHAR(100)
  category : VARCHAR(50)
  created_at : DATETIME
}

entity ANNOUNCEMENTS {
  *announcement_id : BIGINT
  #source_id : INT
  #buyer_id : INT
  --
  external_id : VARCHAR(100)
  title : VARCHAR(500)
  description : LONGTEXT
  estimated_amount : DECIMAL
  currency : VARCHAR(3)
  publication_date : DATETIME
  response_deadline : DATETIME
  location : VARCHAR(255)
  region : VARCHAR(100)
  source_link : TEXT
  status : ENUM
  imported_at : DATETIME
  updated_at : DATETIME
}

entity ANNOUNCEMENT_KEYWORDS {
  *announcement_id : BIGINT
  *keyword_id : INT
  --
  relevance_score : INT
  extraction_type : VARCHAR(50)
  extracted_at : DATETIME
}

entity QUALIFICATION_SCORES {
  *score_id : INT
  #announcement_id : BIGINT
  --
  pertinence_score : INT
  alert_level : VARCHAR(50)
  scoring_reason : TEXT
  keyword_bonus : INT
  amount_bonus : INT
  deadline_bonus : INT
  buyer_bonus : INT
  calculated_at : DATETIME
  updated_at : DATETIME
}

entity NOTIFICATIONS {
  *notification_id : BIGINT
  #announcement_id : BIGINT
  --
  alert_type : VARCHAR(50)
  status : VARCHAR(50)
  priority : INT
  created_at : DATETIME
  sent_at : DATETIME
  acknowledged_at : DATETIME
  message : LONGTEXT
}

entity TECHNICAL_LOGS {
  *log_id : BIGINT
  --
  timestamp : DATETIME
  operation_type : VARCHAR(100)
  operation_source : VARCHAR(100)
  status : VARCHAR(50)
  message : TEXT
  details_json : JSON
  duration_ms : INT
}

entity BUSINESS_LOGS {
  *log_id : BIGINT
  #announcement_id : BIGINT
  --
  timestamp : DATETIME
  operation_type : VARCHAR(100)
  user : VARCHAR(255)
  description : TEXT
  before_state : JSON
  after_state : JSON
}

entity ANNOUNCEMENT_HISTORY {
  *history_id : BIGINT
  #announcement_id : BIGINT
  --
  timestamp : DATETIME
  modification_type : VARCHAR(100)
  modified_column : VARCHAR(100)
  old_value : TEXT
  new_value : TEXT
}

entity BACKUP_LOGS {
  *backup_id : INT
  --
  timestamp : DATETIME
  backup_type : VARCHAR(50)
  backup_file : VARCHAR(500)
  status : VARCHAR(50)
  file_size : BIGINT
  duration_seconds : INT
  error_message : TEXT
}

SOURCES ||--o{ ANNOUNCEMENTS
BUYERS ||--o{ ANNOUNCEMENTS
ANNOUNCEMENTS }o--|| ANNOUNCEMENT_KEYWORDS
KEYWORDS ||--o{ ANNOUNCEMENT_KEYWORDS
ANNOUNCEMENTS ||--|| QUALIFICATION_SCORES
ANNOUNCEMENTS ||--o{ NOTIFICATIONS
ANNOUNCEMENTS ||--o{ BUSINESS_LOGS
ANNOUNCEMENTS ||--o{ ANNOUNCEMENT_HISTORY

note bottom
  Legend:
  * = Primary Key
  # = Foreign Key
end note

@enduml
