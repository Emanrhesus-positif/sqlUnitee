# .gitignore - UNITEE
# Fichiers à ne PAS commiter en git

################################################################################
# ENVIRONNEMENT & SECRETS
################################################################################
.env
.env.local
*.key
*.pem
credentials.json

################################################################################
# DONNÉES SENSIBLES
################################################################################
backups/
*.sql
!sql/schema/*.sql
!sql/logic/*.sql
!sql/analytics/*.sql
!sql/tests/*.sql
*.dump
data/*.csv
data/real_*.json

################################################################################
# CACHE & TEMP
################################################################################
.ipynb_checkpoints/
__pycache__/
*.py[cod]
*.so
build/
dist/
*.egg-info/
venv/
env/
.venv

################################################################################
# IDE
################################################################################
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-workspace
.project

################################################################################
# LOGS
################################################################################
logs/
*.log
*.log.*

################################################################################
# SYSTÈME
################################################################################
.DS_Store
Thumbs.db
.Trashes
node_modules/
data/mysql/

################################################################################
# DATABASE
################################################################################
mysql-bin.*
*.pid

################################################################################
# CACHE
################################################################################
.pip-cache/
plantuml-cache/
.coverage
htmlcov/

################################################################################
# CONFIG LOCAL
################################################################################
config/config.local.yaml
config/sources_config.local.yaml
